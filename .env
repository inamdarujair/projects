# Price provider configuration
# Enable mock pricing (no external API required). Set to true/1 to return sample offers.
PRICE_MOCK=1

# Cache TTL for price results (milliseconds)
PRICE_CACHE_TTL_MS=600000

# Amazon Product Advertising API (optional)
#AMAZON_ACCESS_KEY=
#AMAZON_SECRET_KEY=
#AMAZON_PARTNER_TAG=
#AMAZON_MARKETPLACE=www.amazon.in

# Flipkart Affiliate API (optional)
#FLIPKART_AFFILIATE_ID=
#FLIPKART_AFFILIATE_TOKEN=

# Admin token for component CRUD (for local dev only)
ADMIN_TOKEN=dev-admin

# Server port
PORT=3001
